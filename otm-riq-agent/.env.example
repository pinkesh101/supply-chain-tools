# OTM Rate Inquiry Agent — Environment Variables
# Copy this file to .env and fill in your OTM instance details.
# Never commit .env to GitHub.

OTM_BASE_URL=https://your-otm-instance.otmgtm.us-ashburn-1.ocs.oraclecloud.com
OTM_USERNAME=YOUR_DOMAIN.INTEGRATION
OTM_PASSWORD=your_password_here
OTM_DOMAIN=YOUR_DOMAIN
